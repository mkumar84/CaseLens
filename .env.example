# Supabase/Postgres connection string. If unset, both the backend and the
# gateway fall back to a local SQLite file (./caselens.db) so the whole
# system is runnable without live infra — see shared/config.py.
# DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Anthropic API key. If unset, all four agents fall back to the
# deterministic offline heuristics in agents/heuristics.py, so the gateway,
# policies, seed data, tests, and demo script are still runnable without a
# key. Set this to exercise the real Claude Sonnet-backed agents.
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

# Where agents (and the backend's /agents/* routes) reach the gateway.
# On Railway this should be the gateway service's internal URL.
GATEWAY_URL=http://127.0.0.1:8001

# Where the demo script and any external tooling reach the backend API.
BACKEND_URL=http://127.0.0.1:8000
